APP_ENV=development

# Server configuration
SERVER_ADDRESS=:8080

# CORS configuration
CORS_ALLOWED_ORIGIN=http://localhost:5173

# Database driver and connection source
DB_DRIVER=postgres
DB_SOURCE=postgresql://postgres:password@localhost:5432/polymedia_db?sslmode=disable

# Minio configuration
#MINIO_INTERNAL_ENDPOINT=http://minio:9000
MINIO_INTERNAL_ENDPOINT=http://localhost:9000
MINIO_EXTERNAL_ENDPOINT=http://localhost:9000
MINIO_BUCKET=polymedia-raw
MINIO_ACCESS_KEY=admin_user
MINIO_SECRET_KEY=secure_password_123
